   "source": [
    "applno2text = build_applno2text(text_dataset_paths, set(list(df_pairs['APPLNO']) + list(df_pairs['REF_APPLNO'])))\n",
    "\n",
    "anchor_positive_dataset = build_anchor_positive_dataset(df_pairs, applno2text)\n",
    "# 기존 valid 유지 + 신규 데이터만 분리\n",
    "existing_valid_path = '/nasdata/workspace/2025/14_PatentSearch_2025/yhj/251015_valid_변경실험/02_prep_datasets/valid_doc_dataset'\n",
    "new_valid_path = './02_prep_datasets/valid_doc_dataset_additional'\n",
    "\n",
    "new_train, new_valid = split_new_data_only(\n",
    "    anchor_positive_dataset,\n",
    "    existing_valid_path=existing_valid_path,\n",
    "    new_valid_path=new_valid_path,\n",
    "    split_ratio=0.9\n",
    ")\n"
   ]
