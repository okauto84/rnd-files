   "source": [
    "import os\n",
    "import pickle5 as pickle\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from datasets import load_from_disk, Dataset, concatenate_datasets\n",
    "from collections import defaultdict\n",
    "from tqdm import tqdm\n",
    "from pprint import pprint\n",
    "\n",
    "# =========================================================\n",
    "# 0️⃣ 유틸리티\n",
    "# =========================================================\n",
    "def load_pickle5(filename):\n",
    "    with open(filename, 'rb') as f:\n",
    "        return pickle.load(f)\n",
    "\n",
    "def save_pickle5(data, filename):\n",
    "    with open(filename, 'wb') as f:\n",
    "        pickle.dump(data, f, protocol=pickle.HIGHEST_PROTOCOL)\n",
    "\n",
    "# =========================================================\n",
    "# 1️⃣ 데이터셋 전처리 및 병합\n",
    "# =========================================================\n",
    "def preprocess_dataset(dataset_paths: dict, save_path: str):\n",
    "    pprint(dataset_paths)\n",
    "    ds_list = [Dataset.from_json(dataset_paths[f]) for f in tqdm(dataset_paths, desc=\"데이터셋 로드 중\")]\n",
    "    merged_ds = concatenate_datasets(ds_list)\n",
    "    merged_ds.to_parquet(save_path)\n",
    "    print(f\"✅ 병합 완료: {save_path} ({len(merged_ds):,} rows)\")\n",
    "    return merged_ds\n",
    "\n",
    "# =========================================================\n",
    "# 2️⃣ 섹션 정보 매핑\n",
    "# =========================================================\n",
    "def build_section_dict(bib_data_path, save_path='./02_prep_datasets/section_dict.p'):\n",
    "    try:\n",
    "        section_dict = load_pickle5(save_path)\n",
    "    except:\n",
    "        bib_data = load_pickle5(bib_data_path)\n",
    "        section_dict = {s: [] for s in ['A','B','C','D','E','F','G','H','Y','Unknown']}\n",
    "    \n",
    "        for q, v in tqdm(bib_data.items(), desc=\"섹션 매핑 중\"):\n",
    "            tmp_section = v['CPC'][0][0] if len(v['CPC']) > 0 else 'Unknown'\n",
    "            section_dict[tmp_section].append(q)\n",
    "    \n",
    "        save_pickle5(section_dict, save_path)\n",
    "        print(\"✅ section_dict 저장 완료\")\n",
    "    return section_dict\n",
    "\n",
    "# =========================================================\n",
    "# 3️⃣ 데이터 필터링\n",
    "# =========================================================\n",
    "def filter_dataset_by_section(dataset, filtered_set, section_dict, num_proc=16):\n",
    "    applno_to_section = {applno: sec for sec, applnos in section_dict.items() for applno in applnos}\n",
    "    filtered_ds = dataset.filter(lambda x: x['APPLNO'] in filtered_set, num_proc=num_proc)\n",
    "    filtered_ds = filtered_ds.filter(\n",
    "        lambda x: applno_to_section.get(x['APPLNO']) == applno_to_section.get(x['REF_APPLNO']),\n",
    "        num_proc=num_proc\n",
    "    )\n",
    "    return filtered_ds\n",
    "\n",
    "# =========================================================\n",
    "# 4️⃣ text_dataset → applno2text 매핑\n",
    "# =========================================================\n",
    "def build_applno2text(text_dataset_paths, applno_set, save_path='./02_prep_datasets/new_dataset'):\n",
    "    filtered_datasets = []\n",
    "    for path in tqdm(text_dataset_paths, desc=\"텍스트 데이터 로드 중\"):\n",
    "        ds = load_from_disk(path)\n",
    "        filtered_ds = ds.filter(lambda x: x['applno_field'].split('_')[0] in applno_set, num_proc=16)\n",
    "        filtered_datasets.append(filtered_ds)\n",
    "    \n",
    "    combined_dataset = concatenate_datasets(filtered_datasets)\n",
    "    combined_dataset.save_to_disk('./02_prep_datasets/text_dataset')\n",
    "\n",
    "    def split_applno(example):\n",
    "        applno, field = example['applno_field'].split('_', 1)\n",
    "        example['applno'] = applno\n",
    "        example['field'] = field\n",
    "        return example\n",
    "\n",
    "    combined_dataset = combined_dataset.map(split_applno, num_proc=32)\n",
    "\n",
    "    grouped = defaultdict(list)\n",
    "    for ex in tqdm(combined_dataset, desc=\"그룹화 중\"):\n",
    "        grouped[ex['applno']].append(ex['vector'])\n",
    "    \n",
    "    grouped_list = [{'applno': k, 'text_list': v} for k, v in grouped.items()]\n",
    "    new_dataset = Dataset.from_list(grouped_list)\n",
    "    new_dataset.save_to_disk(save_path)\n",
    "    \n",
    "    applno2text = {ex['applno']: ex['text_list'] for ex in tqdm(new_dataset, desc=\"applno2text 생성 중\")}\n",
    "    return applno2text\n",
    "\n",
    "# =========================================================\n",
    "# 5️⃣ anchor-positive dataset 생성\n",
    "# =========================================================\n",
    "def build_anchor_positive_dataset(df_pairs, applno2text, save_path='./02_prep_datasets/anchor_positive_dataset'):\n",
    "    pairs = []\n",
    "    for _, row in tqdm(df_pairs.iterrows(), total=len(df_pairs), desc=\"anchor-positive 생성\"):\n",
    "        q, a = str(row['APPLNO']), str(row['REF_APPLNO'])\n",
    "        if str(q) not in applno2text or str(a) not in applno2text:\n",
    "            continue\n",
    "        pairs.append({\n",
    "            'query_applno': q,\n",
    "            'answer_applno': a,\n",
    "            'query_text_list': applno2text[q],\n",
    "            'answer_text_list': applno2text[a]\n",
    "        })\n",
    "    dataset = Dataset.from_list(pairs)\n",
    "    dataset.save_to_disk(save_path)\n",
    "    print(f\"✅ anchor_positive_dataset 저장 ({len(dataset)})\")\n",
    "    return dataset\n",
    "\n",
    "# =========================================================\n",
    "# 6️⃣ Train / Valid Split\n",
    "# =========================================================\n",
    "def split_train_valid(anchor_positive_dataset, train_path, valid_path, split_ratio=0.9):\n",
    "    try:\n",
    "        train_dataset = load_from_disk(train_path)\n",
    "        valid_dataset = load_from_disk(valid_path)\n",
    "    except:\n",
    "        unique_applnos = list(set(anchor_positive_dataset['query_applno']))\n",
    "        np.random.seed(42)\n",
    "        np.random.shuffle(unique_applnos)\n",
    "        split_idx = int(len(unique_applnos) * split_ratio)\n",
    "        train_applnos = set(unique_applnos[:split_idx])\n",
    "        valid_applnos = set(unique_applnos[split_idx:])\n",
    "        train_dataset = anchor_positive_dataset.filter(lambda x: x['query_applno'] in train_applnos)\n",
    "        valid_dataset = anchor_positive_dataset.filter(lambda x: x['query_applno'] in valid_applnos)\n",
    "        train_dataset.save_to_disk(train_path)\n",
    "        valid_dataset.save_to_disk(valid_path)\n",
    "    print(f\"✅ Train: {len(train_dataset)}, Valid: {len(valid_dataset)}\")\n",
    "    return train_dataset, valid_dataset\n",
    "\n",
    "# =========================================================\n",
    "# ⭐ 추가된 부분: 신규 데이터만 분리\n",
    "# =========================================================\n",
    "def split_new_data_only(anchor_positive_dataset, existing_valid_path, new_valid_path, split_ratio=0.9):\n",
    "    \"\"\"\n",
    "    기존 valid는 유지하고, anchor_positive_dataset 중 신규 데이터만 따로 split하여 새로운 valid를 생성\n",
    "    \"\"\"\n",
    "    print(f\"📂 기존 valid 로드: {existing_valid_path}\")\n",
    "    existing_valid = load_from_disk(existing_valid_path)\n",
    "    existing_applnos = set(existing_valid['query_applno'])\n",
    "    \n",
    "    print(f\"🔍 기존 valid에 없는 신규 데이터만 추출 중...\")\n",
    "    new_dataset = anchor_positive_dataset.filter(lambda x: x['query_applno'] not in existing_applnos)\n",
    "    print(f\"✅ 신규 데이터 개수: {len(new_dataset)}\")\n",
    "\n",
    "    if len(new_dataset) == 0:\n",
    "        print(\"⚠️ 신규 데이터가 없습니다. 기존 valid만 유지합니다.\")\n",
    "        return None, None\n",
    "\n",
    "    unique_applnos = list(set(new_dataset['query_applno']))\n",
    "    np.random.seed(42)\n",
    "    np.random.shuffle(unique_applnos)\n",
    "    split_idx = int(len(unique_applnos) * split_ratio)\n",
    "    train_applnos = set(unique_applnos[:split_idx])\n",
    "    valid_applnos = set(unique_applnos[split_idx:])\n",
    "\n",
    "    new_train = new_dataset.filter(lambda x: x['query_applno'] in train_applnos)\n",
    "    new_valid = new_dataset.filter(lambda x: x['query_applno'] in valid_applnos)\n",
    "\n",
    "    new_valid.save_to_disk(new_valid_path)\n",
    "    print(f\"✅ 신규 valid 저장 완료: {new_valid_path} ({len(new_valid):,} rows)\")\n",
    "    return new_train, new_valid\n",
    "\n",
    "\n",
    "# =========================================================\n",
    "# 7️⃣ 전체 실행\n",
    "# =========================================================\n",
    "if __name__ == \"__main__\":\n",
    "\n",
    "    # 신규 포함 데이터셋 경로 정의\n",
    "    dataset_path = {\n",
    "        '자동구축데이터셋': {f'{i}차수': f'01_org_datasets/자동구축데이터셋_{i}차수_전달용.json' for i in range(1,9)},  # ✅ 7차 추가\n",
    "        '수작업데이터셋': {f'{i}차수': f'01_org_datasets/수작업구축데이터_{i}차수_전달용.json' for i in range(1,6)},  # ✅ 5차 추가\n",
    "    }\n",
    "\n",
    "    # 1️⃣ 통합 전처리\n",
    "    자동_ds = preprocess_dataset(dataset_path['자동구축데이터셋'], './02_prep_datasets/자동구축데이터셋_전처리완료')\n",
    "    수작업_ds = preprocess_dataset(dataset_path['수작업데이터셋'], './02_prep_datasets/수작업데이터셋_전처리완료')\n",
    "\n",
    "    # 2️⃣ 섹션 정보\n",
    "    section_dict = build_section_dict('/nasdata/data/text/02_kiprisplus_rawdata/08_KIPO_OPN_BackTo202412/ko_data_info_ver202412_ver2.p')\n",
    "\n",
    "    # 3️⃣ 필터링\n",
    "    print('필터링할 데이터 선정')\n",
    "    unique_applnos = set(자동_ds.unique('APPLNO')) | set(수작업_ds.unique('APPLNO'))  \n",
    "    interesed_section = []\n",
    "    for s in ['C','H','E','F','G','A','B','D']:\n",
    "        interesed_section.extend(section_dict[s])\n",
    "    interesed_section_set = set(interesed_section)\n",
    "    \n",
    "    test_dataset = load_pickle5('/nasdata/workspace/2025/14_PatentSearch_2025/data/01_eval_data/01_eval_section_booster_113219.p')\n",
    "    test_keys_set = set([v[0] for v in test_dataset.values()])\n",
    "\n",
    "    \n",
    "    filtered_applnos = [applno for applno in tqdm(unique_applnos) if applno in interesed_section_set and applno not in test_keys_set]\n",
    "\n",
    "    print('필터링 시작')\n",
    "    filtered_자동 = filter_dataset_by_section(자동_ds, set(filtered_applnos), section_dict)\n",
    "    filtered_수작업 = filter_dataset_by_section(수작업_ds, set(filtered_applnos), section_dict)\n",
    "    print('필터링 끝')\n",
    "\n",
    "    # 4️⃣ df 병합\n",
    "    print('df 병합 시작')\n",
    "    df_자동 = filtered_자동.to_pandas()\n",
    "    df_수작업 = filtered_수작업.to_pandas()\n",
    "    df_pairs = pd.concat([df_자동, df_수작업], ignore_index=True)[['APPLNO','REF_APPLNO']].drop_duplicates()\n",
    "    df_pairs.to_csv('./02_prep_datasets/pair_df.csv', index=False)\n",
    "    print('df 저장 완료')\n",
    "\n",
    "    # 5️⃣ text_dataset → applno2text 생성\n",
    "    text_dataset_paths = [\n",
    "        '/nasdata/workspace/2025/14_PatentSearch_2025/kmh/01_model_all_doc_test_540/01_data_pre_proc/pre_data_field5_divide4_arrow/pubdata_202412_5field_input_512_div4_text1/',\n",
    "        '/nasdata/workspace/2025/14_PatentSearch_2025/kmh/01_model_all_doc_test_540/01_data_pre_proc/pre_data_field5_divide4_arrow/pubdata_202412_5field_input_512_div4_text2/',\n",
    "        '/nasdata/workspace/2025/14_PatentSearch_2025/kmh/01_model_all_doc_test_540/01_data_pre_proc/pre_data_field5_divide4_arrow/pubdata_202412_5field_input_512_div4_text3/',\n",
    "        '/nasdata/workspace/2025/14_PatentSearch_2025/kmh/01_model_all_doc_test_540/01_data_pre_proc/pre_data_field5_divide4_arrow/pubdata_202412_5field_input_512_div4_text4/',\n",
    "    \n",
    "    ]\n",
    "    print('applno2text')\n",
    "    applno2text = build_applno2text(text_dataset_paths, set(list(df_pairs['APPLNO']) + list(df_pairs['REF_APPLNO'])))\n",
    "    \n",
    "    anchor_positive_dataset = build_anchor_positive_dataset(df_pairs, applno2text)\n",
    "    # 기존 valid 유지 + 신규 데이터만 분리\n",
    "    existing_valid_path = '/nasdata/workspace/2025/14_PatentSearch_2025/yhj/251015_valid_변경실험/02_prep_datasets/valid_doc_dataset'\n",
    "    new_valid_path = './02_prep_datasets/valid_doc_dataset_additional'\n",
    "\n",
    "    new_train, new_valid = split_new_data_only(\n",
    "        anchor_positive_dataset,\n",
    "        existing_valid_path=existing_valid_path,\n",
    "        new_valid_path=new_valid_path,\n",
    "        split_ratio=0.9\n",
    "    )\n"
   ]
  },
