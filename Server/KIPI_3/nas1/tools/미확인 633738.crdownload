     ]
    }
   ],
   "source": [
    "def split_new_data_only(anchor_positive_dataset, existing_valid_path, new_valid_path, split_ratio=0.9):\n",
    "    \"\"\"\n",
    "    기존 valid는 유지하고, anchor_positive_dataset 중 신규 데이터만 따로 split하여 새로운 valid를 생성\n",
    "    \"\"\"\n",
    "\n",
    "    print(f\"✅ anchor_positive_dataset 데이터 개수: {len(anchor_positive_dataset)}\")\n",
    "    \n",
    "    print(f\"📂 기존 valid 로드: {existing_valid_path}\")\n",
    "    \n",
    "    existing_valid = load_from_disk(existing_valid_path)\n",
    "    existing_applnos = set(existing_valid['query_applno'])\n",
    "    \n",
    "    print(f\"🔍 기존 valid에 없는 신규 데이터만 추출 중...\")\n",
    "    print(len(anchor_positive_dataset))\n",
    "    new_dataset = anchor_positive_dataset.filter(lambda x: x['query_applno'] not in existing_applnos)\n",
    "    print(len(new_dataset))\n",
    "    print(f\"✅ 신규 데이터 개수: {len(new_dataset)}\")\n",
    "\n",
    "    if len(new_dataset) == 0:\n",
    "        print(\"⚠️ 신규 데이터가 없습니다. 기존 valid만 유지합니다.\")\n",
    "        return None, None\n",
    "\n",
    "    unique_applnos = list(set(new_dataset['query_applno']))\n",
    "    np.random.seed(42)\n",
    "    np.random.shuffle(unique_applnos)\n",
    "    split_idx = int(len(anchor_positive_dataset) * split_ratio)\n",
    "    train_applnos = set(unique_applnos[:split_idx])\n",
    "    valid_applnos = set(unique_applnos[split_idx:])\n",
    "\n",
    "    new_train = new_dataset.filter(lambda x: x['query_applno'] in train_applnos)\n",
    "    new_valid = new_dataset.filter(lambda x: x['query_applno'] in valid_applnos)\n",
    "\n",
    "    new_valid = concatenate_datasets([new_valid, existing_valid])\n",
    "\n",
    "    # new_train.save_to_disk(new_valid_path)\n",
    "    # print(f\"✅ 신규 train 저장 완료: {new_valid_path} ({len(new_train):,} rows)\")\n",
    "\n",
    "    new_train_path = './02_prep_datasets/train_doc_dataset_additional'\n",
    "\n",
    "    new_train.save_to_disk(new_train_path)\n",
    "    print(f\"✅ 신규 train 저장 완료: {new_train_path} ({len(new_train):,} rows)\")\n",
    "    \n",
    "    new_valid.save_to_disk(new_valid_path)\n",
    "    print(f\"✅ 신규 valid 저장 완료: {new_valid_path} ({len(new_valid):,} rows)\")\n",
    "    return new_train, new_valid\n",
    "\n",
    "new_train, new_valid = split_new_data_only(\n",
    "        anchor_positive_dataset,\n",
    "        existing_valid_path=existing_valid_path,\n",
    "        new_valid_path=new_valid_path,\n",
    "        split_ratio=0.9\n",
    "    )"
   ]
  },
