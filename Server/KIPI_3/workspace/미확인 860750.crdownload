   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import os\n",
    "import time\n",
    "\n",
    "# 1. 경로 설정\n",
    "tsv_path = \"/nasdata/workspace/2026/14_PatentSearch/hjin/data/manual_v7_patent_doc_kss_testpool_sentences_top100.tsv\"\n",
    "npz_base_path = \"/nasdata2/data/2025_pilot_system/text_vector_npz_files_by_one\"\n",
    "\n",
    "# 2. TSV 파일 읽기\n",
    "df_tsv = pd.read_csv(tsv_path, sep=\"\\t\", header=None, dtype=str, usecols=[0, 1])\n",
    "df_tsv.columns = ['id_tsv', 'text_tsv']\n",
    "\n",
    "current_applno = None\n",
    "npz_dict = {}\n",
    "total_rows = len(df_tsv)\n",
    "\n",
    "# 파일 쓰기 모드 오픈\n",
    "f_missing = open(\"missing_ids.txt\", \"w\", encoding=\"utf-8\")\n",
    "f_mismatch = open(\"mismatched_texts.txt\", \"w\", encoding=\"utf-8\")\n",
    "\n",
    "print(f\"🚀 총 {total_rows:,}건 분석 및 파일 저장 시작...\")\n",
    "start_time = time.time()\n",
    "\n",
    "for i, row in enumerate(df_tsv.itertuples(), 1):\n",
    "    raw_id = str(row.id_tsv).strip()\n",
    "    tsv_text = str(row.text_tsv).strip()\n",
    "    \n",
    "    if not raw_id: continue\n",
    "\n",
    "    target_applno = raw_id.split(':')[0] if ':' in raw_id else raw_id\n",
    "    \n",
    "    # NPZ 로드 (캐싱)\n",
    "    if target_applno != current_applno:\n",
    "        current_applno = target_applno\n",
    "        npz_path = os.path.join(npz_base_path, f\"{current_applno}.npz\")\n",
    "        if os.path.exists(npz_path):\n",
    "            try:\n",
    "                data_npz = np.load(npz_path, allow_pickle=True)\n",
    "                npz_dict = dict(zip(data_npz[\"sentence_ids\"], data_npz[\"texts\"]))\n",
    "            except: npz_dict = {}\n",
    "        else: npz_dict = {}\n",
    "\n",
    "    normalized_id = raw_id.replace(\":\", \"_\", 1)\n",
    "    \n",
    "    # 대조 및 저장\n",
    "    if normalized_id in npz_dict:\n",
    "        npz_text = str(npz_dict[normalized_id]).strip()\n",
    "        if tsv_text != npz_text:\n",
    "            # 내용 불일치 상세 저장 (전체 문장)\n",
    "            f_mismatch.write(f\"ID: {normalized_id}\\n\")\n",
    "            f_mismatch.write(f\"[TSV]: {tsv_text}\\n\")\n",
    "            f_mismatch.write(f\"[NPZ]: {npz_text}\\n\")\n",
    "            f_mismatch.write(\"-\" * 100 + \"\\n\")\n",
    "    else:\n",
    "        # ID 부재 목록 저장\n",
    "        f_missing.write(f\"{normalized_id}\\n\")\n",
    "\n",
    "    if i % 10000 == 0 or i == total_rows:\n",
    "        elapsed = time.time() - start_time\n",
    "        print(f\"⏳ [{i:,}/{total_rows:,}] 진행 중... 소요시간: {elapsed:.1f}초\", end='\\r')\n",
    "\n",
    "# 파일 닫기\n",
    "f_missing.close()\n",
    "f_mismatch.close()\n",
    "\n",
    "print(\"\\n\" + \"=\"*40)\n",
    "print(f\"✅ 분석 완료 및 파일 저장 성공!\")\n",
    "print(f\"1. ID 부재 리스트: missing_ids.txt\")\n",
    "print(f\"2. 내용 불일치 상세: mismatched_texts.txt\")\n",
    "print(\"=\"*40)"
   ]
  },
