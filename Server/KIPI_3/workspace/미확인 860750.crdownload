   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "# 1. 경로 설정 (기존과 동일)\n",
    "tsv_path = \"/nasdata/workspace/2026/14_PatentSearch/hjin/data/manual_v1_patent_doc_kss_testpool_sentences_top100.tsv\"\n",
    "npz_base_path = \"/nasdata2/data/2025_pilot_system/text_vector_npz_files_by_one\"\n",
    "\n",
    "# 2. 불일치 샘플 리스트 (사용자님이 올려주신 샘플 ID들 중 일부 추출)\n",
    "target_ids = ['1020140160988_ABS:0', '1020140160988_ABS:1', '1020140160988_PTCLS:1:0']\n",
    "\n",
    "# 3. 분석을 위해 TSV 로드\n",
    "df_tsv = pd.read_csv(tsv_path, sep=\"\\t\", header=None, dtype=str, usecols=[0, 1])\n",
    "df_tsv.columns = ['id_tsv', 'text_tsv']\n",
    "\n",
    "print(\"🔎 불일치 문장 상세 대조 분석\\n\")\n",
    "\n",
    "for target_id in target_ids:\n",
    "    # TSV에서 해당 ID 찾기 (NPZ 형태인 _ 를 다시 : 로 바꿔서 검색)\n",
    "    raw_id_for_tsv = target_id.replace(\"_\", \":\", 1)\n",
    "    tsv_row = df_tsv[df_tsv['id_tsv'] == raw_id_for_tsv]\n",
    "    \n",
    "    if tsv_row.empty:\n",
    "        print(f\"❌ ID {target_id}: TSV에서 찾을 수 없습니다.\")\n",
    "        continue\n",
    "        \n",
    "    tsv_text = tsv_row['text_tsv'].values[0].strip()\n",
    "    \n",
    "    # NPZ 로드\n",
    "    applno = target_id.split('_')[0]\n",
    "    npz_path = os.path.join(npz_base_path, f\"{applno}.npz\")\n",
    "    \n",
    "    if os.path.exists(npz_path):\n",
    "        data_npz = np.load(npz_path, allow_pickle=True)\n",
    "        npz_dict = dict(zip(data_npz[\"sentence_ids\"], data_npz[\"texts\"]))\n",
    "        npz_text = str(npz_dict.get(target_id, \"ID 없음\")).strip()\n",
    "    else:\n",
    "        npz_text = \"NPZ 파일 없음\"\n",
    "\n",
    "    # 출력 및 비교\n",
    "    print(f\"🆔 [ID]: {target_id}\")\n",
    "    print(f\"📄 [TSV 문장] ({len(tsv_text)}자): {repr(tsv_text)}\")\n",
    "    print(f\"📦 [NPZ 문장] ({len(npz_text)}자): {repr(npz_text)}\")\n",
    "    \n",
    "    if tsv_text == npz_text:\n",
    "        print(\"✅ 결과: 일치 (공백 문제였을 가능성)\")\n",
    "    else:\n",
    "        print(\"🚨 결과: 불일치\")\n",
    "        # 어떤 부분이 다른지 힌트 (앞부분 20글자만 대조)\n",
    "        if tsv_text[:20] != npz_text[:20]:\n",
    "            print(f\"   💡 힌트: 문장 시작부터 다릅니다.\")\n",
    "        else:\n",
    "            print(f\"   💡 힌트: 문장 끝부분이나 중간 오타를 확인하세요.\")\n",
    "    print(\"-\" * 80)"
   ]
