   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from collections import Counter\n",
    "\n",
    "# 1. 설정 및 경로\n",
    "file_path = \"sentence_lengths_all.csv\"\n",
    "output_image = \"sentence_length_distribution.png\"\n",
    "\n",
    "# 빈도수 계산을 위한 Counter 객체 (메모리 효율적)\n",
    "length_counts = Counter()\n",
    "\n",
    "print(f\"🚀 7.4억 건 데이터 집계 시작 (이 작업은 시간이 소요될 수 있습니다)...\")\n",
    "\n",
    "# 2. Chunk 단위로 읽으면서 길이별 빈도수 계산\n",
    "chunksize = 10**6  # 100만 건씩 읽기\n",
    "try:\n",
    "    for chunk in pd.read_csv(file_path, chunksize=chunksize):\n",
    "        # 각 청크의 길이 빈도수를 업데이트\n",
    "        length_counts.update(chunk['length'])\n",
    "except FileNotFoundError:\n",
    "    print(f\"❌ 파일을 찾을 수 없습니다: {file_path}\")\n",
    "    exit()\n",
    "\n",
    "# 3. 집계된 데이터를 바탕으로 통계 데이터프레임 생성\n",
    "df_counts = pd.DataFrame.from_dict(length_counts, orient='index', columns=['count']).reset_index()\n",
    "df_counts.columns = ['length', 'count']\n",
    "df_counts = df_counts.sort_values('length')\n",
    "\n",
    "# 기초 통계 계산 (가중 평균 등)\n",
    "total_count = df_counts['count'].sum()\n",
    "mean_len = (df_counts['length'] * df_counts['count']).sum() / total_count\n",
    "# 중앙값 근사치 계산\n",
    "df_counts['cum_count'] = df_counts['count'].cumsum()\n",
    "median_len = df_counts[df_counts['cum_count'] >= total_count / 2]['length'].iloc[0]\n",
    "\n",
    "print(f\"✅ 집계 완료! (총 문장 수: {total_count:,}건)\")\n",
    "\n",
    "# 4. 시각화 (2개의 그래프 그리기)\n",
    "fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(12, 12))\n",
    "\n",
    "# 그래프 1: 일반 히스토그램 (길이 1000자 이하 집중)\n",
    "# 너무 긴 문장은 그래프를 왜곡시키므로 1000자 이하만 먼저 시각적으로 확인\n",
    "df_zoom = df_counts[df_counts['length'] <= 1000]\n",
    "ax1.bar(df_zoom['length'], df_zoom['count'], color='skyblue', width=1.0)\n",
    "ax1.axvline(mean_len, color='red', linestyle='--', label=f'Mean: {mean_len:.1f}')\n",
    "ax1.axvline(median_len, color='green', linestyle='-', label=f'Median: {median_len}')\n",
    "ax1.set_title(\"Sentence Length Distribution (Under 1000 chars)\", fontsize=15)\n",
    "ax1.set_xlabel(\"Sentence Length (characters)\")\n",
    "ax1.set_ylabel(\"Frequency\")\n",
    "ax1.legend()\n",
    "\n",
    "# 그래프 2: 로그 스케일 분포 (전체 범위 확인용)\n",
    "# X축과 Y축 모두 로그 스케일을 적용하여 1자 문장과 10000자 문장을 동시에 확인\n",
    "ax2.scatter(df_counts['length'], df_counts['count'], alpha=0.5, s=10, color='royalblue')\n",
    "ax2.set_xscale('log')\n",
    "ax2.set_yscale('log')\n",
    "ax2.set_title(\"Total Sentence Length Distribution (Log-Log Scale)\", fontsize=15)\n",
    "ax2.set_xlabel(\"Sentence Length (Log Scale)\")\n",
    "ax2.set_ylabel(\"Frequency (Log Scale)\")\n",
    "ax2.grid(True, which=\"both\", ls=\"-\", alpha=0.2)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(output_image)\n",
    "print(f\"💾 그래프가 저장되었습니다: {output_image}\")\n",
    "plt.show()\n",
    "\n",
    "# 5. KSS 문제 진단용 주요 구간 통계 출력\n",
    "print(\"\\n\" + \"=\"*50)\n",
    "print(\"🧐 KSS 품질 진단용 구간별 통계\")\n",
    "print(\"-\" * 50)\n",
    "sections = [\n",
    "    (\"과도 분리 의심 (1~10자)\", 0, 10),\n",
    "    (\"단문 구간 (10~30자)\", 10, 30),\n",
    "    (\"일반 문장 (30~200자)\", 30, 200),\n",
    "    (\"장문 구간 (201~400자)\", 200, 400),\n",
    "    (\"분리 실패 의심 (400자 초과)\", 400, float('inf'))\n",
    "]\n",
    "\n",
    "for label, start, end in sections:\n",
    "    sec_count = df_counts[(df_counts['length'] > start) & (df_counts['length'] <= end)]['count'].sum()\n",
    "    ratio = (sec_count / total_count) * 100\n",
    "    print(f\"{label:<25}: {sec_count:>15,.0f}건 ({ratio:>6.2f}%)\")\n",
    "print(\"=\"*50)"
   ]
