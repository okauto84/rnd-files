   "cell_type": "code",
   "execution_count": 44,
   "id": "94c5306a-9c2b-4c92-8494-2602b03a53d3",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✨ [1020237041433] 완료 | 문장: 1239개 | 카테고리: 03_long_error\n"
     ]
    }
   ],
   "source": [
    "import pickle\n",
    "import os\n",
    "import re\n",
    "import html as _html\n",
    "import kss\n",
    "\n",
    "# --- [1] 전처리 함수 ---\n",
    "def sanitize_with_p_attributes(raw):\n",
    "    if not isinstance(raw, str): return _html.escape(\"\" if raw is None else str(raw))\n",
    "    s = re.sub(r'(?is)<script.*?>.*?</script>', '', raw)\n",
    "    s = s.replace(\"<br></br>\", \"<br>\").replace(\"<br/>\", \"<br>\")\n",
    "    s = re.sub(r'</?figref[^>]*>|/abstract-figure[^>]*>|/summary[^>]*>|/AmendStatus[^>]*>', '', s)\n",
    "    s = re.sub(r'</?(?!(?:p\\b|/p|br\\b))\\w+[^>]*>', '', s)\n",
    "    s = re.sub(r'<p\\b[^>]*>\\s*</p>', '', s, flags=re.IGNORECASE)\n",
    "    return s\n",
    "\n",
    "def sanitize_all_html(raw):\n",
    "    if not isinstance(raw, str): return _html.escape(\"\" if raw is None else str(raw))\n",
    "    s = re.sub(r'(?is)<script.*?>.*?</script>', '', raw)\n",
    "    s = s.replace(\"<br></br>\", \" \").replace(\"<br/>\", \" \").replace(\"<br>\", \" \").replace(\"</p>\", \" \")\n",
    "    s = re.sub(r'<[^>]*>', '', s)\n",
    "    s = _html.unescape(s)\n",
    "    return re.sub(r'\\s+', ' ', s).strip()\n",
    "\n",
    "# --- [2] 모든 형태의 SPEC 데이터를 추출하는 함수 ---\n",
    "def collect_spec_data(data_item, ori_res, clean_res):\n",
    "    \"\"\"리스트, 딕셔너리, 문자열이 뒤섞인 SPEC 구조에서 데이터를 재귀적으로 수집\"\"\"\n",
    "    if isinstance(data_item, str):\n",
    "        if data_item.strip():\n",
    "            ori_res.append(sanitize_with_p_attributes(data_item))\n",
    "            clean_res.append(sanitize_all_html(data_item))\n",
    "    elif isinstance(data_item, list):\n",
    "        for item in data_item:\n",
    "            collect_spec_data(item, ori_res, clean_res)\n",
    "    elif isinstance(data_item, dict):\n",
    "        for val in data_item.values():\n",
    "            collect_spec_data(val, ori_res, clean_res)\n",
    "\n",
    "# [추가 필수] 이전 답변에서 알려드렸던 안전 분할 함수를 꼭 같이 넣어주세요!\n",
    "def chunk_text_safely(text, max_len=5000):\n",
    "    \"\"\"마침표(.) 단위로 분할. 소스코드를 대비해 max_len을 5000자로 확 줄였습니다.\"\"\"\n",
    "    if len(text) <= max_len: return [text]\n",
    "    \n",
    "    raw_parts = re.split(r'(?<=\\.)\\s+', text)\n",
    "    chunks = []\n",
    "    current_chunk = \"\"\n",
    "    \n",
    "    for part in raw_parts:\n",
    "        if len(part) > max_len:\n",
    "            if current_chunk:\n",
    "                chunks.append(current_chunk)\n",
    "                current_chunk = \"\"\n",
    "            for i in range(0, len(part), max_len):\n",
    "                chunks.append(part[i:i+max_len])\n",
    "            continue\n",
    "            \n",
    "        if len(current_chunk) + len(part) + 1 > max_len:\n",
    "            chunks.append(current_chunk)\n",
    "            current_chunk = part\n",
    "        else:\n",
    "            current_chunk = (current_chunk + \" \" + part).strip() if current_chunk else part\n",
    "            \n",
    "    if current_chunk: chunks.append(current_chunk)\n",
    "    return chunks\n",
    "\n",
    "# --- [수정된 문장 분리 함수] ---\n",
    "def split_with_tags(applno, section_name, raw_tag, clean_text, sub_key=None):\n",
    "    # 1. 5000자 단위로 강제 청크 분할 (Mecab 멈춤 방지)\n",
    "    split_sents = []\n",
    "    for chunk in chunk_text_safely(clean_text, max_len=5000):\n",
    "        if not chunk.strip(): continue\n",
    "        try:\n",
    "            split_sents.extend(kss.split_sentences(chunk, backend=\"mecab\"))\n",
    "        except:\n",
    "            # Mecab이 소스코드에 질려서 에러를 뱉으면, 쪼개지 않고 청크 그대로 삽입\n",
    "            split_sents.append(chunk)\n",
    "\n",
    "    current_pos = 0\n",
    "    for i, sent in enumerate(split_sents):\n",
    "        s_id = f\"{applno}_{section_name}:{sub_key}:{i}\" if sub_key else f\"{applno}_{section_name}:{i}\"\n",
    "        \n",
    "        t_len = len(sent.strip())\n",
    "        status = \"normal\"\n",
    "        \n",
    "        # 2. [핵심 방어막] 문장이 500자를 넘어가면 소스코드로 간주하고 정규식 매칭 포기\n",
    "        if t_len > 500:\n",
    "            sent_tag = sent  # 태그 매칭을 생략하고 원문 그대로 삽입\n",
    "            status = \"long_err\" # 어차피 너무 길어서 에러로 분류됨\n",
    "            current_pos += len(sent) # 위치만 대략적으로 건너뜀\n",
    "        else:\n",
    "            # 500자 이하의 정상적인 문장만 정규식(re.search) 실행\n",
    "            search_pattern = \"\".join([re.escape(c) + r\"(?:\\s*<[^>]*>\\s*)*\" if c.strip() else r\"\\s+\" for c in sent])\n",
    "            match = re.search(search_pattern, raw_tag[current_pos:])\n",
    "            \n",
    "            if match:\n",
    "                sent_tag = raw_tag[current_pos:current_pos + match.end()].strip()\n",
    "                current_pos += match.end()\n",
    "            else:\n",
    "                sent_tag = sent\n",
    "                \n",
    "            if t_len >= 200: status = \"long_err\"\n",
    "            elif t_len < 10 and len(clean_text.strip()) >= 10: status = \"short_err\"\n",
    "        \n",
    "        final_sentence_ids.append(s_id)\n",
    "        final_texts.append(sent)\n",
    "        final_texts_tag.append(sent_tag)\n",
    "        sentence_statuses.append(status)\n",
    "\n",
    "# --- [4] 메인 실행부 ---\n",
    "applno = \"1020237041433\"\n",
    "pickle_path = f\"/nasdata/data/text/02_kiprisplus_rawdata/09_KIPO_OPN_BackTo202512/by_one/{applno}.p\"\n",
    "\n",
    "with open(pickle_path, \"rb\") as f:\n",
    "    data = pickle.load(f)\n",
    "\n",
    "# 리스트 초기화\n",
    "final_sentence_ids, final_texts, final_texts_tag, sentence_statuses = [], [], [], []\n",
    "\n",
    "# 1. ABS 처리\n",
    "raw_abs = data.get(\"ABS\", \"\")\n",
    "if raw_abs:\n",
    "    split_with_tags(applno, \"ABS\", sanitize_with_p_attributes(raw_abs), sanitize_all_html(raw_abs))\n",
    "\n",
    "# 2. PTCLS 처리\n",
    "claims = data.get(\"PTCLS\", {})\n",
    "for c_num in sorted(claims.keys(), key=lambda x: int(x) if x.isdigit() else x):\n",
    "    c_text = claims[c_num]\n",
    "    split_with_tags(applno, \"PTCLS\", sanitize_with_p_attributes(c_text), sanitize_all_html(c_text), sub_key=c_num)\n",
    "\n",
    "# 3. SPEC 처리 (핵심: 어떤 구조든 싹 긁어옴)\n",
    "spec_data = data.get(\"SPEC\", {})\n",
    "if isinstance(spec_data, dict):\n",
    "    for s_key in sorted(spec_data.keys()):\n",
    "        # 특정 키(REST_TEXT 등) 내부의 데이터를 리스트로 수집\n",
    "        ori_list, clean_list = [], []\n",
    "        collect_spec_data(spec_data[s_key], ori_list, clean_list)\n",
    "        \n",
    "        for idx, (rt, ct) in enumerate(zip(ori_list, clean_list)):\n",
    "            split_with_tags(applno, \"SPEC\", rt, ct, sub_key=f\"{s_key}:{idx}\")\n",
    "\n",
    "# 4. 저장 및 결과 출력\n",
    "if not final_sentence_ids:\n",
    "    print(f\"❌ 데이터 추출 실패! 현재 SPEC 구조: {type(spec_data)}\")\n",
    "    if isinstance(spec_data, dict): print(f\"🔍 SPEC 키 목록: {spec_data.keys()}\")\n",
    "else:\n",
    "    # 카테고리 판별 및 저장 로직 (이전과 동일)\n",
    "    def finalize_category(stats):\n",
    "        if \"long_err\" in stats: return \"03_long_error\"\n",
    "        if \"short_err\" in stats: return \"01_short_error\"\n",
    "        return \"02_normal\"\n",
    "\n",
    "    folder = finalize_category(sentence_statuses)\n",
    "    out_path = f\"/nasdata/workspace/2026/14_PatentSearch/hjin/split_results/{folder}\"\n",
    "    os.makedirs(out_path, exist_ok=True)\n",
    "    \n",
    "    with open(os.path.join(out_path, f\"{applno}_split.p\"), \"wb\") as f:\n",
    "        pickle.dump({\"sentence_ids\": final_sentence_ids, \"texts\": final_texts, \"texts_tag\": final_texts_tag}, f)\n",
    "\n",
    "    print(f\"✨ [{applno}] 완료 | 문장: {len(final_sentence_ids)}개 | 카테고리: {folder}\")"
   ]
  },
