   "source": [
    "import numpy as np\n",
    "import os\n",
    "import glob\n",
    "import pandas as pd\n",
    "import time\n",
    "\n",
    "# 1. 경로 설정\n",
    "npz_base_path = \"/nasdata2/data/2025_pilot_system/text_vector_npz_files_by_one\"\n",
    "npz_files = glob.glob(os.path.join(npz_base_path, \"*.npz\"))\n",
    "\n",
    "# 분석용 변수\n",
    "lengths = []\n",
    "short_samples = []  # 과도 분리 샘플 (10자 이하)\n",
    "long_samples = []   # 분리 실패 샘플 (1000자 이상)\n",
    "abnormal_ends = []  # 종결 어미 불량 샘플\n",
    "total_files = len(npz_files)\n",
    "\n",
    "print(f\"🚀 총 {total_files:,}개의 NPZ 파일 분석 시작 (1,000개 단위 로그 출력)\\n\")\n",
    "start_time = time.time()\n",
    "\n",
    "# 종결 어미 정의\n",
    "end_chars = ('.', '?', '!', '\"', \"'\")\n",
    "\n",
    "for i, npz_path in enumerate(npz_files, 1):\n",
    "    try:\n",
    "        data = np.load(npz_path, allow_pickle=True)\n",
    "        texts = [str(t) for t in data[\"texts\"]]\n",
    "        \n",
    "        for text in texts:\n",
    "            t_strip = text.strip()\n",
    "            length = len(t_strip)\n",
    "            lengths.append(length)\n",
    "            \n",
    "            # 시사점 분석을 위한 샘플 수집 (메모리 보호를 위해 최대 100개씩만)\n",
    "            if length <= 10 and len(short_samples) < 100:\n",
    "                short_samples.append(t_strip)\n",
    "            elif length >= 1000 and len(long_samples) < 100:\n",
    "                long_samples.append(t_strip[:200] + \"...\")\n",
    "            \n",
    "            if not t_strip.endswith(end_chars) and len(abnormal_ends) < 100:\n",
    "                abnormal_ends.append(t_strip[-50:]) # 끝부분 50자 저장\n",
    "\n",
    "    except Exception as e:\n",
    "        continue\n",
    "\n",
    "    # --- 진행 상황 출력 구간 ---\n",
    "    if i % 1000 == 0 or i == total_files:\n",
    "        elapsed = time.time() - start_time\n",
    "        percent = (i / total_files) * 100\n",
    "        # \\r을 사용하여 한 줄에서 실시간으로 숫자 갱신\n",
    "        print(f\"⏳ 진행률: {percent:6.2f}% | 처리: {i:,}/{total_files:,} | 소요시간: {elapsed:.1f}초\", end='\\r')\n",
    "\n",
    "# 2. 통계 분석\n",
    "print(\"\\n\\n\" + \"=\"*50)\n",
    "print(\"📊 문장 길이 기본 통계\")\n",
    "lengths_arr = np.array(lengths)\n",
    "print(f\"- 최소 길이: {lengths_arr.min()} 자\")\n",
    "print(f\"- 최대 길이: {lengths_arr.max():,} 자\")\n",
    "print(f\"- 평균 길이: {lengths_arr.mean():.2f} 자\")\n",
    "print(f\"- 중앙값: {np.median(lengths_arr)} 자\")\n",
    "print(\"=\"*50)\n",
    "\n",
    "# 3. KSS 문제점 분석 결과\n",
    "print(\"\\n🔍 KSS 문장 분리 문제점 샘플\")\n",
    "\n",
    "print(f\"\\n[!] 과도 분리 의심 (10자 이하 샘플):\")\n",
    "for s in list(set(short_samples))[:10]: # 중복 제거 후 10개\n",
    "    print(f\"   - {repr(s)}\")\n",
    "\n",
    "print(f\"\\n[!] 분리 실패 의심 (1000자 이상 샘플):\")\n",
    "for s in list(set(long_samples))[:3]:\n",
    "    print(f\"   - {s}\")\n",
    "\n",
    "print(f\"\\n[!] 비정상 종결 의심 (마침표 없이 끝남):\")\n",
    "for s in list(set(abnormal_ends))[:5]:\n",
    "    print(f\"   - ...{repr(s)}\")\n",
    "\n",
    "# 4. 전체 길이 분포 CSV 저장 (히스토그램용)\n",
    "pd.Series(lengths).to_csv(\"sentence_lengths_all.csv\", index=False)"
   ]
  },
