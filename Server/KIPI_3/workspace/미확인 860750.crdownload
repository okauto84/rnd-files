   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "# 1. 파일 경로 설정\n",
    "tsv_path = \"/nasdata/workspace/2026/14_PatentSearch/hjin/data/manual_v1_patent_doc_kss_testpool_sentences_top100.tsv\"\n",
    "npz_base_path = \"/nasdata2/data/2025_pilot_system/text_vector_npz_files_by_one\"\n",
    "\n",
    "# 2. TSV 파일 읽기\n",
    "df_tsv = pd.read_csv(tsv_path, sep=\"\\t\", header=None, names=['id_tsv', 'text_tsv'], dtype={'id_tsv': str})\n",
    "\n",
    "results = []\n",
    "current_applno = None\n",
    "npz_dict = {}\n",
    "total_rows = len(df_tsv)\n",
    "\n",
    "print(f\"🚀 총 {total_rows}개의 문장 비교를 시작합니다.\\n\")\n",
    "\n",
    "# enumerate를 사용하여 확실한 숫자 인덱스(i)를 생성합니다.\n",
    "for i, (idx, row) in enumerate(df_tsv.iterrows(), 1):\n",
    "    raw_id = str(row['id_tsv'])\n",
    "    tsv_text = str(row['text_tsv']).strip()\n",
    "    \n",
    "    # ID에서 applno 추출\n",
    "    target_applno = raw_id.split(':')[0] if ':' in raw_id else raw_id\n",
    "    \n",
    "    # 3. applno가 바뀔 때 로그 출력 및 NPZ 로드\n",
    "    if target_applno != current_applno:\n",
    "        current_applno = target_applno\n",
    "        npz_path = os.path.join(npz_base_path, f\"{current_applno}.npz\")\n",
    "        \n",
    "        # 여기서 i는 enumerate 덕분에 항상 정수입니다.\n",
    "        # print(f\"📦 [{i}/{total_rows}] 현재 처리 중인 출원번호: {current_applno}\")\n",
    "        \n",
    "        if os.path.exists(npz_path):\n",
    "            try:\n",
    "                data_npz = np.load(npz_path, allow_pickle=True)\n",
    "                npz_dict = dict(zip(data_npz[\"sentence_ids\"], data_npz[\"texts\"]))\n",
    "            except Exception as e:\n",
    "                print(f\"   ❌ NPZ 로드 실패 ({current_applno}): {e}\")\n",
    "                npz_dict = {}\n",
    "        else:\n",
    "            print(f\"   ⚠️  NPZ 파일이 없습니다: {npz_path}\")\n",
    "            npz_dict = {}\n",
    "\n",
    "    # 4. ID 정규화 및 비교\n",
    "    normalized_id = raw_id.replace(\":\", \"_\", 1)\n",
    "    \n",
    "    if normalized_id in npz_dict:\n",
    "        npz_text = str(npz_dict[normalized_id]).strip()\n",
    "        is_same = (tsv_text == npz_text)\n",
    "        \n",
    "        if not is_same:\n",
    "            print(f\"   ❌ 불일치 발견! ID: {normalized_id}\")\n",
    "            # 내용 확인용 출력 (앞뒤 공백 문제일 수 있으니 표시)\n",
    "            print(f\"      TSV: [{tsv_text[:30]}...]\")\n",
    "            print(f\"      NPZ: [{npz_text[:30]}...]\")\n",
    "        \n",
    "        results.append({\"applno\": current_applno, \"id\": normalized_id, \"is_same\": is_same})\n",
    "    else:\n",
    "        # 가끔 진행 상황을 보기 위해 ID 없음도 출력 (너무 많으면 주석 처리 하세요)\n",
    "        # print(f\"   ❓ NPZ 내 ID 없음: {normalized_id}\")\n",
    "        results.append({\"applno\": current_applno, \"id\": normalized_id, \"is_same\": False})\n",
    "\n",
    "# 5. 최종 결과 요약\n",
    "df_result = pd.DataFrame(results)\n",
    "if not df_result.empty:\n",
    "    match_count = df_result['is_same'].sum()\n",
    "    fail_count = len(df_result) - match_count\n",
    "\n",
    "    print(\"\\n\" + \"=\"*40)\n",
    "    print(f\"✅ 비교 완료!\")\n",
    "    print(f\"- 일치: {match_count}건\")\n",
    "    print(f\"- 불일치: {fail_count}건\")\n",
    "    print(\"=\"*40)"
   ]
