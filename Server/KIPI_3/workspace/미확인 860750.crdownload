    "import pandas as pd\n",
    "import numpy as np\n",
    "import os\n",
    "import time\n",
    "\n",
    "# 1. 경로 설정\n",
    "tsv_path = \"/nasdata/workspace/2026/14_PatentSearch/hjin/data/auto_v1_patent_doc_kss_testpool_sentences_top100.tsv\"\n",
    "npz_base_path = \"/nasdata2/data/2025_pilot_system/text_vector_npz_files_by_one\"\n",
    "\n",
    "# 2. TSV 파일 읽기\n",
    "df_tsv = pd.read_csv(tsv_path, sep=\"\\t\", header=None, dtype=str, usecols=[0, 1])\n",
    "df_tsv.columns = ['id_tsv', 'text_tsv']\n",
    "\n",
    "results = []\n",
    "current_applno = None\n",
    "npz_dict = {}\n",
    "total_rows = len(df_tsv)\n",
    "\n",
    "# 통계를 위한 카운터\n",
    "id_missing_count = 0  # NPZ에 ID 자체가 없는 경우\n",
    "text_mismatch_count = 0  # ID는 있는데 텍스트가 다른 경우\n",
    "\n",
    "print(f\"🚀 총 {total_rows:,}건 대조 시작 (ID 부재 제외, 내용 불일치 집중)\")\n",
    "start_time = time.time()\n",
    "\n",
    "for i, row in enumerate(df_tsv.itertuples(), 1):\n",
    "    raw_id = str(row.id_tsv).strip()\n",
    "    tsv_text = str(row.text_tsv).strip()\n",
    "    \n",
    "    if not raw_id: continue\n",
    "\n",
    "    target_applno = raw_id.split(':')[0] if ':' in raw_id else raw_id\n",
    "    \n",
    "    # NPZ 캐싱 로드\n",
    "    if target_applno != current_applno:\n",
    "        current_applno = target_applno\n",
    "        npz_path = os.path.join(npz_base_path, f\"{current_applno}.npz\")\n",
    "        if os.path.exists(npz_path):\n",
    "            try:\n",
    "                data_npz = np.load(npz_path, allow_pickle=True)\n",
    "                npz_dict = dict(zip(data_npz[\"sentence_ids\"], data_npz[\"texts\"]))\n",
    "            except: npz_dict = {}\n",
    "        else: npz_dict = {}\n",
    "\n",
    "    normalized_id = raw_id.replace(\":\", \"_\", 1)\n",
    "    \n",
    "    # --- 핵심 로직 변경 부분 ---\n",
    "    if normalized_id in npz_dict:\n",
    "        npz_text = str(npz_dict[normalized_id]).strip()\n",
    "        is_same = (tsv_text == npz_text)\n",
    "        \n",
    "        if not is_same:\n",
    "            text_mismatch_count += 1\n",
    "            # 내용이 다른 경우 나중에 분석하기 위해 저장\n",
    "            results.append({\n",
    "                \"id\": normalized_id,\n",
    "                \"status\": \"TEXT_MISMATCH\",\n",
    "                \"tsv_text\": tsv_text,\n",
    "                \"npz_text\": npz_text\n",
    "            })\n",
    "    else:\n",
    "        id_missing_count += 1\n",
    "        # ID 자체가 없는 경우는 결과 리스트에 status만 기록 (필요 시)\n",
    "        # results.append({\"id\": normalized_id, \"status\": \"ID_MISSING\"})\n",
    "\n",
    "    if i % 1000 == 0 or i == total_rows:\n",
    "        elapsed = time.time() - start_time\n",
    "        print(f\"⏳ [{i:,}/{total_rows:,}] 처리 중... (누적 내용불일치: {text_mismatch_count}건)\", end='\\r')\n",
    "\n",
    "# 4. 결과 정리 및 요약\n",
    "print(\"\\n\" + \"=\"*40)\n",
    "print(f\"📊 최종 분석 보고\")\n",
    "print(f\"- 전체 검토 문장: {total_rows:,}건\")\n",
    "print(f\"- 🔎 NPZ 내 ID 부재: {id_missing_count:,}건 (분석 제외)\")\n",
    "print(f\"- ❌ 실제 내용 불일치: {text_mismatch_count:,}건\")\n",
    "print(\"=\"*40)\n",
    "\n",
    "# 내용이 다른 샘플 출력\n",
    "if text_mismatch_count > 0:\n",
    "    print(\"\\n🔍 실제 내용 불일치 샘플 (상세):\")\n",
    "    df_mismatch = pd.DataFrame(results)\n",
    "    for idx, row in df_mismatch.head(5).iterrows():\n",
    "        print(f\"\\n[{idx+1}] ID: {row['id']}\")\n",
    "        print(f\"   TSV: {repr(row['tsv_text'][:100])}...\")\n",
    "        print(f\"   NPZ: {repr(row['npz_text'][:100])}...\")\n",
    "        print(\"-\" * 50)\n",
    "else:\n",
    "    print(\"\\n✅ ID가 존재하는 모든 문장의 텍스트가 완벽히 일치합니다!\")"
   ]
  },
