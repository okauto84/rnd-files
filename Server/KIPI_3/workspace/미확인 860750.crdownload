   "source": [
    "import os\n",
    "import pickle\n",
    "import re\n",
    "import html as _html\n",
    "import kss\n",
    "\n",
    "# --- [1] 전처리 및 청크 분할 함수 ---\n",
    "def sanitize_with_p_attributes(raw):\n",
    "    if not isinstance(raw, str): return _html.escape(\"\" if raw is None else str(raw))\n",
    "    s = raw.replace('\\u3000', ' ')\n",
    "    s = re.sub(r'(?is)<script.*?>.*?</script>', '', s)\n",
    "    s = s.replace(\"<br></br>\", \"<br>\").replace(\"<br/>\", \"<br>\")\n",
    "    s = re.sub(r'</?figref[^>]*>|/abstract-figure[^>]*>|/summary[^>]*>|/AmendStatus[^>]*>', '', s)\n",
    "    s = re.sub(r'</?(?!(?:p\\b|/p|br\\b))\\w+[^>]*>', '', s)\n",
    "    s = re.sub(r'<p\\b[^>]*>\\s*</p>', '', s, flags=re.IGNORECASE)\n",
    "    return s\n",
    "\n",
    "def sanitize_all_html(raw):\n",
    "    if not isinstance(raw, str): return _html.escape(\"\" if raw is None else str(raw))\n",
    "    s = raw.replace('\\u3000', ' ')\n",
    "    s = re.sub(r'(?is)<script.*?>.*?</script>', '', s)\n",
    "    s = s.replace(\"</p>\", \"\\n\")  # 💡 핵심: </p>가 \\n으로 변환됨\n",
    "    s = re.sub(r'<[^>]*>', ' ', s)\n",
    "    s = _html.unescape(s)\n",
    "    s = re.sub(r'[ \\t\\r\\f\\v]+', ' ', s)\n",
    "    s = re.sub(r'\\n+', '\\n', s)\n",
    "    return s.strip()\n",
    "\n",
    "def collect_spec_data(data_item, ori_res, clean_res):\n",
    "    if isinstance(data_item, str):\n",
    "        if data_item.strip():\n",
    "            ori_res.append(sanitize_with_p_attributes(data_item))\n",
    "            clean_res.append(sanitize_all_html(data_item))\n",
    "    elif isinstance(data_item, list):\n",
    "        for item in data_item:\n",
    "            collect_spec_data(item, ori_res, clean_res)\n",
    "    elif isinstance(data_item, dict):\n",
    "        for val in data_item.values():\n",
    "            collect_spec_data(val, ori_res, clean_res)\n",
    "\n",
    "# 💡 이 함수는 이제 '최후의 보루'로만 사용됩니다.\n",
    "def chunk_text_safely(text, max_len=500000):\n",
    "    if len(text) <= max_len: return [text]\n",
    "    \n",
    "    raw_parts = re.split(r'(?<=\\.)\\s+', text)\n",
    "    chunks = []\n",
    "    current_chunk = \"\"\n",
    "    for part in raw_parts:\n",
    "        if len(part) > max_len:\n",
    "            if current_chunk:\n",
    "                chunks.append(current_chunk)\n",
    "                current_chunk = \"\"\n",
    "            for i in range(0, len(part), max_len):\n",
    "                chunks.append(part[i:i+max_len])\n",
    "            continue\n",
    "        if len(current_chunk) + len(part) + 1 > max_len:\n",
    "            chunks.append(current_chunk)\n",
    "            current_chunk = part\n",
    "        else:\n",
    "            current_chunk = (current_chunk + \" \" + part).strip() if current_chunk else part\n",
    "    if current_chunk: chunks.append(current_chunk)\n",
    "    return chunks\n",
    "\n",
    "# --- [2] 디버깅용 메인 실행부 ---\n",
    "\n",
    "applno = \"1020050129268\" \n",
    "pickle_path = f\"/nasdata/data/text/02_kiprisplus_rawdata/09_KIPO_OPN_BackTo202512/by_one/{applno}.p\"\n",
    "\n",
    "print(f\"🚀 [{applno}] 정밀 분석을 시작합니다...\\n\")\n",
    "\n",
    "with open(pickle_path, \"rb\") as f:\n",
    "    data = pickle.load(f)\n",
    "\n",
    "final_ids, final_txts, final_tags, statuses = [], [], [], []\n",
    "\n",
    "def inner_split_debug(sec_name, raw_tag, clean_text, sub_key=None):\n",
    "    sec_id = f\"{sec_name}:{sub_key}\" if sub_key else sec_name\n",
    "    print(f\"  ▶️ [{sec_id}] 텍스트 길이: {len(clean_text):,}자 | <p> 태그(문단) 기준 분리 중...\")\n",
    "    \n",
    "    split_sents = []\n",
    "    \n",
    "    # 💡 [핵심 개선] clean_text를 통째로 넘기지 않고, </p>가 변환된 \\n 기준으로 먼저 자릅니다!\n",
    "    paragraphs = clean_text.split('\\n')\n",
    "    \n",
    "    for p_idx, paragraph in enumerate(paragraphs):\n",
    "        paragraph = paragraph.strip()\n",
    "        if not paragraph: continue\n",
    "        \n",
    "        # 💡 문단 단위로 잘랐음에도 불구하고 500000자가 넘는 \"미친 문단\"일 경우에만 안전 청킹 사용\n",
    "        if len(paragraph) > 500000:\n",
    "            chunks = chunk_text_safely(paragraph, max_len=500000)\n",
    "        else:\n",
    "            chunks = [paragraph]\n",
    "            \n",
    "        for chunk in chunks:\n",
    "            try:\n",
    "                # 단락 단위로 들어가기 때문에 KSS가 더 문맥을 잘 파악합니다.\n",
    "                split_sents.extend(kss.split_sentences(chunk, backend=\"mecab\"))\n",
    "            except Exception as e:\n",
    "                print(f\"      ⚠️ Mecab 에러 발생 (문단 {p_idx}): {e}\")\n",
    "                split_sents.append(chunk)\n",
    "\n",
    "    print(f\"  ✔️ [{sec_id}] Mecab 분리 완료! 총 {len(split_sents)}문장. 태그 매칭 시작...\")\n",
    "\n",
    "    current_pos = 0\n",
    "    for i, sent in enumerate(split_sents):\n",
    "        s_id = f\"{applno}_{sec_name}:{sub_key}:{i}\" if sub_key else f\"{applno}_{sec_name}:{i}\"\n",
    "        \n",
    "        if i % 100 == 0 and i > 0:\n",
    "            print(f\"      ... 태그 매칭 진행 중: {i}/{len(split_sents)}\")\n",
    "\n",
    "        t_len = len(sent.strip())\n",
    "        status = \"normal\"\n",
    "\n",
    "        if t_len > 400:\n",
    "            sent_tag = sent\n",
    "            status = \"long_err\"\n",
    "            current_pos += len(sent)\n",
    "        else:\n",
    "            words = sent.split()\n",
    "            if not words:\n",
    "                sent_tag = sent\n",
    "                current_pos += len(sent)\n",
    "            else:\n",
    "                search_pattern = r\"(?:<[^>]+>|\\s)*?\".join([re.escape(w) for w in words])\n",
    "                \n",
    "                window_size = max(len(sent) * 10, 20000)\n",
    "                search_target = raw_tag[current_pos : current_pos + window_size]\n",
    "                \n",
    "                pure_target = re.sub(r'<[^>]+>', '', search_target)\n",
    "                pure_target = _html.unescape(pure_target)\n",
    "                pure_target = re.sub(r'\\s+', '', pure_target)\n",
    "                pure_sent = re.sub(r'\\s+', '', sent)\n",
    "                \n",
    "                if pure_sent and pure_sent not in pure_target:\n",
    "                    sent_tag = sent\n",
    "                    current_pos += len(sent)\n",
    "                else:\n",
    "                    try:\n",
    "                        match = re.search(search_pattern, search_target)\n",
    "                        if match:\n",
    "                            sent_tag = search_target[match.start() : match.end()].strip()\n",
    "                            current_pos += match.end()\n",
    "                        else:\n",
    "                            sent_tag = sent\n",
    "                            current_pos += len(sent)\n",
    "                    except Exception as e:\n",
    "                        print(f\"      ❌ 정규식 에러 발생! 문장 인덱스: {i}\")\n",
    "                        print(f\"      문장 내용: {sent[:100]}...\")\n",
    "                        raise e\n",
    "        \n",
    "        if t_len >= 200: status = \"long_err\"\n",
    "        elif t_len < 10 and len(clean_text.strip()) >= 10: status = \"short_err\"\n",
    "        \n",
    "        final_ids.append(s_id)\n",
    "        final_txts.append(sent)\n",
    "        final_tags.append(sent_tag)\n",
    "        statuses.append(status)\n",
    "        \n",
    "    print(f\"  ✅ [{sec_id}] 태그 매칭 및 처리 완료!\\n\")\n",
    "\n",
    "# 1. ABS 처리\n",
    "print(\"[1] ABS 처리 시작\")\n",
    "raw_abs = data.get(\"ABS\", \"\")\n",
    "if raw_abs: inner_split_debug(\"ABS\", sanitize_with_p_attributes(raw_abs), sanitize_all_html(raw_abs))\n",
    "\n",
    "# 2. PTCLS 처리\n",
    "print(\"[2] PTCLS 처리 시작\")\n",
    "claims = data.get(\"PTCLS\", {})\n",
    "if isinstance(claims, dict):\n",
    "    valid_keys = [k for k in claims.keys() if str(k).strip()]\n",
    "    for c_num in sorted(valid_keys, key=lambda x: (0, int(x)) if str(x).isdigit() else (1, str(x))):\n",
    "        inner_split_debug(\"PTCLS\", sanitize_with_p_attributes(claims[c_num]), sanitize_all_html(claims[c_num]), sub_key=c_num)\n",
    "\n",
    "# 3. SPEC 처리\n",
    "print(\"[3] SPEC 처리 시작 (재귀 탐색)\")\n",
    "spec_root = data.get(\"SPEC\", {})\n",
    "if isinstance(spec_root, dict):\n",
    "    valid_s_keys = [k for k in spec_root.keys() if str(k).strip()]\n",
    "    for s_key in sorted(valid_s_keys, key=lambda x: str(x)):\n",
    "        ori_list, clean_list = [], []\n",
    "        collect_spec_data(spec_root[s_key], ori_list, clean_list)\n",
    "        for idx, (rt, ct) in enumerate(zip(ori_list, clean_list)):\n",
    "            inner_split_debug(\"SPEC\", rt, ct, sub_key=f\"{s_key}:{idx}\")\n",
    "\n",
    "print(\"🎉 모든 섹션 처리가 무사히 완료되었습니다!\")\n",
    "print(f\"총 추출된 문장 수: {len(final_ids):,}개\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
