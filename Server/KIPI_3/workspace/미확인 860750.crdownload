    "import numpy as np\n",
    "import os\n",
    "\n",
    "# 문제가 된 출원번호\n",
    "applno = \"1020140160988\"\n",
    "npz_path = f\"/nasdata2/data/2025_pilot_system/text_vector_npz_files_by_one/{applno}.npz\"\n",
    "\n",
    "if os.path.exists(npz_path):\n",
    "    data = np.load(npz_path, allow_pickle=True)\n",
    "    sentence_ids = data[\"sentence_ids\"].tolist()\n",
    "    \n",
    "    print(f\"📂 [{applno}.npz] 내부 분석\")\n",
    "    print(f\"📊 총 ID 개수: {len(sentence_ids)}개\")\n",
    "    print(\"-\" * 50)\n",
    "    \n",
    "    # 1. 처음 10개 ID 출력\n",
    "    print(\"📌 [처음 10개 ID]:\")\n",
    "    for s_id in sentence_ids:\n",
    "        print(f\"   {s_id}\")\n",
    "        \n",
    "    # 2. 특정 키워드(예: ABS)가 포함된 ID가 있는지 확인\n",
    "    abs_ids = [s for s in sentence_ids if \"ABS\" in s]\n",
    "    print(f\"\\n📌 [ABS 관련 ID 개수]: {len(abs_ids)}개\")\n",
    "    if abs_ids:\n",
    "        print(f\"   샘플: {abs_ids[:5]}\")\n",
    "        \n",
    "    # 3. TSV에서 우리가 찾으려던 ID가 있는지 직접 확인\n",
    "    target_search = \"1020140160988_ABS:0\"\n",
    "    if target_search in sentence_ids:\n",
    "        print(f\"\\n✅ {target_search} 가 실제로 존재합니다!\")\n",
    "    else:\n",
    "        print(f\"\\n❌ {target_search} 가 존재하지 않습니다. 형식을 다시 확인해야 합니다.\")\n",
    "else:\n",
    "    print(f\"❌ {applno}.npz 파일 자체가 경로에 없습니다.\")"
   ]
