   "source": [
    "import numpy as np\n",
    "import os\n",
    "import glob\n",
    "import time\n",
    "\n",
    "# 1. 경로 설정\n",
    "npz_base_path = \"/nasdata2/data/2025_pilot_system/text_vector_npz_files_by_one\"\n",
    "npz_files = glob.glob(os.path.join(npz_base_path, \"*.npz\"))\n",
    "\n",
    "total_files = len(npz_files)\n",
    "end_chars = ('.', '?', '!', '\"', \"'\")\n",
    "\n",
    "# 통계 계산용 변수 (메모리 최소화)\n",
    "total_sentences = 0\n",
    "min_len = float('inf')\n",
    "max_len = 0\n",
    "sum_len = 0\n",
    "\n",
    "print(f\"🚀 총 {total_files:,}개 파일 분석 및 전체 샘플 기록 시작\\n\")\n",
    "start_time = time.time()\n",
    "\n",
    "# 2. 파일 오픈 (전체 데이터를 실시간으로 기록)\n",
    "with open(\"sentence_lengths_all.csv\", \"w\", encoding=\"utf-8\") as f_len, \\\n",
    "     open(\"all_short_sentences.txt\", \"w\", encoding=\"utf-8\") as f_short, \\\n",
    "     open(\"all_long_sentences.txt\", \"w\", encoding=\"utf-8\") as f_long, \\\n",
    "     open(\"all_abnormal_ends.txt\", \"w\", encoding=\"utf-8\") as f_abnormal:\n",
    "    \n",
    "    f_len.write(\"length\\n\") # CSV 헤더\n",
    "\n",
    "    for i, npz_path in enumerate(npz_files, 1):\n",
    "        try:\n",
    "            data = np.load(npz_path, allow_pickle=True)\n",
    "            texts = [str(t) for t in data[\"texts\"]]\n",
    "            \n",
    "            for text in texts:\n",
    "                t_strip = text.strip()\n",
    "                if not t_strip: continue\n",
    "                \n",
    "                length = len(t_strip)\n",
    "                \n",
    "                # 1) 모든 문장 길이 기록\n",
    "                f_len.write(f\"{length}\\n\")\n",
    "                \n",
    "                # 2) 실시간 통계 갱신\n",
    "                total_sentences += 1\n",
    "                sum_len += length\n",
    "                if length < min_len: min_len = length\n",
    "                if length > max_len: max_len = length\n",
    "                \n",
    "                # 3) 조건별 전체 문장 기록 (제한 없이 모두 저장)\n",
    "                if length <= 10:\n",
    "                    f_short.write(f\"{repr(t_strip)}\\n\")\n",
    "                \n",
    "                elif length >= 1000:\n",
    "                    f_long.write(f\"{repr(t_strip)}\\n\")\n",
    "                \n",
    "                if not t_strip.endswith(end_chars):\n",
    "                    f_abnormal.write(f\"{repr(t_strip)}\\n\")\n",
    "\n",
    "        except Exception:\n",
    "            continue\n",
    "\n",
    "        # 진행 상황 출력 (1,000개 파일마다)\n",
    "        if i % 1000 == 0 or i == total_files:\n",
    "            elapsed = time.time() - start_time\n",
    "            percent = (i / total_files) * 100\n",
    "            print(f\"⏳ 진행률: {percent:6.2f}% | 처리: {i:,}/{total_files:,} | 소요시간: {elapsed:.1f}초\", end='\\r')\n",
    "\n",
    "# 3. 최종 요약 보고\n",
    "print(\"\\n\\n\" + \"=\"*50)\n",
    "print(\"📊 분석 완료 보고서\")\n",
    "if total_sentences > 0:\n",
    "    print(f\"- 분석된 총 문장 수: {total_sentences:,} 건\")\n",
    "    print(f\"- 최소 길이: {min_len} 자\")\n",
    "    print(f\"- 최대 길이: {max_len:,} 자\")\n",
    "    print(f\"- 평균 길이: {sum_len/total_sentences:.2f} 자\")\n",
    "print(\"=\"*50)\n",
    "\n",
    "print(\"\\n✅ 다음 파일들에 모든 결과가 저장되었습니다:\")\n",
    "print(f\"- all_short_sentences.txt  (10자 이하 전체)\")\n",
    "print(f\"- all_long_sentences.txt   (1000자 이상 전체)\")\n",
    "print(f\"- all_abnormal_ends.txt    (종결 어미 불량 전체)\")\n",
    "print(f\"- sentence_lengths_all.csv (전체 길이 통계)\")"
   ]
  },
