    "import numpy as np\n",
    "import os\n",
    "\n",
    "applno = \"1019900004092\"\n",
    "npz_path = os.path.join(\"/nasdata2/data/2025_pilot_system/text_vector_npz_files_by_one\", f\"{applno}.npz\")\n",
    "\n",
    "data = np.load(npz_path, allow_pickle=True)\n",
    "\n",
    "sentence_ids = data[\"sentence_ids\"].tolist()\n",
    "texts = data[\"texts\"].tolist()\n",
    "\n",
    "print(sentence_ids)\n",
    "print(texts)"
   ]
