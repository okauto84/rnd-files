   "source": [
    "import os\n",
    "import pickle\n",
    "import re\n",
    "import html as _html\n",
    "from tqdm.notebook import tqdm\n",
    "from soynlp.word import WordExtractor\n",
    "from konlpy.tag import Mecab\n",
    "\n",
    "# --- [1] 설정 영역: 경로 및 파라미터 ---\n",
    "# 실제 사용하시는 경로로 설정되어 있는지 확인해주세요.\n",
    "PICKLE_DIR = \"/nasdata/data/text/02_kiprisplus_rawdata/09_KIPO_OPN_BackTo202512/by_one/\"\n",
    "OUTPUT_USER_DIC = \"patent_user_dic.csv\"\n",
    "MIN_COUNT = 5  # 단어 추출 최소 빈도\n",
    "\n",
    "# --- [2] 전처리 로직 (기존 제공해주신 로직 반영) ---\n",
    "\n",
    "def sanitize_all_html(raw):\n",
    "    \"\"\"HTML 태그 제거 및 순수 텍스트 추출\"\"\"\n",
    "    if not isinstance(raw, str): return \"\"\n",
    "    s = raw.replace('\\u3000', ' ')\n",
    "    s = re.sub(r'(?is)<script.*?>.*?</script>', '', s)\n",
    "    s = s.replace(\"</p>\", \"\\n\")  \n",
    "    s = re.sub(r'<[^>]*>', ' ', s)\n",
    "    s = _html.unescape(s)\n",
    "    s = re.sub(r'[ \\t\\r\\f\\v]+', ' ', s)\n",
    "    s = re.sub(r'\\n+', '\\n', s)\n",
    "    return s.strip()\n",
    "\n",
    "def extract_text_recursive(data_item, res_list):\n",
    "    \"\"\"SPEC 등 복잡한 구조에서 텍스트만 재귀적으로 수집\"\"\"\n",
    "    if isinstance(data_item, str):\n",
    "        clean_txt = sanitize_all_html(data_item)\n",
    "        if clean_txt:\n",
    "            res_list.append(clean_txt)\n",
    "    elif isinstance(data_item, list):\n",
    "        for item in data_item:\n",
    "            extract_text_recursive(item, res_list)\n",
    "    elif isinstance(data_item, dict):\n",
    "        for val in data_item.values():\n",
    "            extract_text_recursive(val, res_list)\n",
    "\n",
    "def get_jongsung_tf(word):\n",
    "    \"\"\"한글 받침 유무 판별 (T/F)\"\"\"\n",
    "    if not word: return 'F'\n",
    "    last_char = word[-1]\n",
    "    if 0xAC00 <= ord(last_char) <= 0xD7A3:\n",
    "        return 'T' if (ord(last_char) - 0xAC00) % 28 > 0 else 'F'\n",
    "    return 'F'\n",
    "\n",
    "# --- [3] 데이터 이터레이터 클래스 ---\n",
    "\n",
    "class PatentCorpus:\n",
    "    def __init__(self, directory, limit=None):\n",
    "        self.directory = directory\n",
    "        # .p 확장자 파일 리스트\n",
    "        all_files = [f for f in os.listdir(directory) if f.endswith('.p')]\n",
    "        if limit:\n",
    "            self.file_list = all_files[:limit]\n",
    "        else:\n",
    "            self.file_list = all_files\n",
    "        print(f\"✅ 처리 대상 파일 수: {len(self.file_list):,}개\")\n",
    "\n",
    "    def __iter__(self):\n",
    "        for file_name in tqdm(self.file_list, desc=\"📄 [Step 1] 텍스트 추출\"):\n",
    "            file_path = os.path.join(self.directory, file_name)\n",
    "            try:\n",
    "                with open(file_path, 'rb') as f:\n",
    "                    data = pickle.load(f)\n",
    "                \n",
    "                doc_texts = []\n",
    "                # 1. ABS 처리\n",
    "                abs_data = data.get(\"ABS\", \"\")\n",
    "                if abs_data:\n",
    "                    doc_texts.append(sanitize_all_html(abs_data))\n",
    "                \n",
    "                # 2. PTCLS 처리\n",
    "                claims = data.get(\"PTCLS\", {})\n",
    "                extract_text_recursive(claims, doc_texts)\n",
    "                \n",
    "                # 3. SPEC 처리\n",
    "                spec = data.get(\"SPEC\", {})\n",
    "                extract_text_recursive(spec, doc_texts)\n",
    "                \n",
    "                # 전체 텍스트 합치기 및 불필요한 기호 제거\n",
    "                full_text = \"\\n\".join(doc_texts)\n",
    "                clean_content = re.sub(r'[^가-힣a-zA-Z0-9\\s]', ' ', full_text)\n",
    "                yield re.sub(r'\\s+', ' ', clean_content).strip()\n",
    "            except:\n",
    "                continue\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.file_list)\n",
    "\n",
    "# --- [4] 메인 실행 함수 ---\n",
    "\n",
    "def process_large_scale_patent():\n",
    "    # 560만 개 전체를 돌리기 전, 10만 개로 속도 테스트를 하려면 limit=100000 추가\n",
    "    corpus = PatentCorpus(PICKLE_DIR) \n",
    "    \n",
    "    print(\"\\n🧠 [Step 2] soynlp 단어 학습 시작 (통계 계산 중)...\")\n",
    "    # max_l_length를 10으로 제한하여 메모리 효율 확보\n",
    "    word_extractor = WordExtractor(max_l_length=10, max_r_length=10)\n",
    "    word_extractor.train(corpus) \n",
    "    \n",
    "    print(\"\\n🔍 [Step 3] 후보 단어 추출 및 점수 계산...\")\n",
    "    word_scores = word_extractor.extract()\n",
    "\n",
    "    print(f\"\\n📝 [Step 4] MeCab 미등록 용어 선별 및 CSV 저장...\")\n",
    "    mecab = Mecab()\n",
    "    new_words_count = 0\n",
    "    seen_words = set()\n",
    "    \n",
    "    with open(OUTPUT_USER_DIC, 'w', encoding='utf-8') as f:\n",
    "        for word, score in tqdm(word_scores.items(), desc=\"🔍 사전 후보 검증\"):\n",
    "            # 최소 빈도(MIN_COUNT) 수동 필터링 (extract 파라미터 미작동 대비)\n",
    "            # 2글자 이상, 응집도 0.1 이상인 경우만 처리\n",
    "            if len(word) < 2 or score.cohesion_forward < 0.1:\n",
    "                continue\n",
    "            \n",
    "            # MeCab 사전 존재 여부 확인\n",
    "            pos_result = mecab.pos(word)\n",
    "            is_already_known = (len(pos_result) == 1 and pos_result[0][1] in ['NNG', 'NNP'])\n",
    "            \n",
    "            if not is_already_known and word not in seen_words:\n",
    "                jongsung = get_jongsung_tf(word)\n",
    "                # Cost -1000으로 강제 인식 설정\n",
    "                line = f\"{word},,,,NNP,*,{jongsung},{word},*,*,*,*\\n\"\n",
    "                f.write(line)\n",
    "                seen_words.add(word)\n",
    "                new_words_count += 1\n",
    "\n",
    "    print(f\"\\n✨ 모든 작업 완료! 총 {new_words_count:,}개의 신규 단어가 등록되었습니다.\")\n",
    "    print(f\"📂 결과 파일: {os.path.abspath(OUTPUT_USER_DIC)}\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    process_large_scale_patent()"
   ]
  }
 ],
